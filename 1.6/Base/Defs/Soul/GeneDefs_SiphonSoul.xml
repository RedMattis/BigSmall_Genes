<Defs>
  <GeneDef>
    <defName>BS_ConsumeSoul</defName>
    <label>siphon soul</label>
    <displayCategory>Archite</displayCategory>
    <description>Grants the ability to drain the essence of a downed foe; killing them in the process. The ability grants Soul Power and steals a small amount of the target's highest skill. The effect has diminishing returns. Dramatically more effective on psychically sensitive targets (above 100%), targets with many archite genes, and targets with soul power themselves.</description>
    <iconPath>GeneIcons/BS_SoulEater</iconPath>
    <abilities>
      <li>BS_ConsumeSoul</li>
    </abilities>
    <descriptionHyperlinks>
      <AbilityDef>BS_ConsumeSoul</AbilityDef>
    </descriptionHyperlinks>
    <biostatMet>0</biostatMet>
    <biostatArc>1</biostatArc>
    <minAgeActive>5</minAgeActive>
    <selectionWeight>1</selectionWeight>
    <biostatCpx>4</biostatCpx>
  </GeneDef>

  <AbilityDef ParentName="AbilityTouchBase">
    <defName>BS_ConsumeSoul</defName>
    <label>siphon soul</label>
    <description>Siphon power from a downed foe. This will kill them and cause irreversible damage.</description>
    <iconPath>GeneIcons/BS_SoulEater</iconPath>
    <displayOrder>100</displayOrder>
    <warmupMote>Mote_ResurrectAbility</warmupMote>
    <warmupStartSound>Resurrect_Cast</warmupStartSound>
    <hostile>true</hostile>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <verbProperties>
      <verbClass>Verb_CastAbilityTouch</verbClass>
      <drawAimPie>true</drawAimPie>
      <range>-1</range>
      <warmupTime>3</warmupTime>
      <targetParams>
        <canTargetSelf>false</canTargetSelf>
        <canTargetBuildings>false</canTargetBuildings>
        <canTargetMechs>false</canTargetMechs>
        <canTargetBloodfeeders>true</canTargetBloodfeeders>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="BigAndSmall.CompProperties_ConsumeSoul">
        <siphonSoul>
          <type>ConsumeSoul</type>
          <gainFactor>20</gainFactor>
          <gainSkill>15</gainSkill>
          
        </siphonSoul>
      </li>
      <li Class="CompProperties_AbilityFleckOnTarget">
        <fleckDef>PsycastPsychicEffect</fleckDef>
        <scale>0.6</scale>
      </li>
    </comps>
    <aiCanUse>false</aiCanUse>
  </AbilityDef>

  <GeneDef>
    <defName>BS_ConsumeSoul_Enslave</defName>
    <label>siphon soul (husk)</label>
    <description>Grants the ability to drain the essence of a downed foe; subjugating them in the process. The ability grants Soul Power and steals a small amount of the target's highest skill. The effect has diminishing returns. Dramatically more effective on psychically sensitive targets (above 100%), targets with many archite genes, and targets with soul power themselves.</description>
    <iconPath>GeneIcons/BS_SoulEater</iconPath>
    <prerequisite>BS_ConsumeSoul</prerequisite>
    <abilities>
      <li>BS_ConsumeSoul_Enslave</li>
    </abilities>
    <descriptionHyperlinks>
      <AbilityDef>BS_ConsumeSoul_Enslave</AbilityDef>
    </descriptionHyperlinks>
    <displayCategory>BS_Soul_Category</displayCategory>
    <biostatMet>0</biostatMet>
    <biostatArc>0</biostatArc>
    <minAgeActive>5</minAgeActive>
    <selectionWeight>1</selectionWeight>
    <biostatCpx>3</biostatCpx>
  </GeneDef>

  <AbilityDef ParentName="AbilityTouchBase">
    <defName>BS_ConsumeSoul_Enslave</defName>
    <label>create husk</label>
    <description>Siphon power from a downed foe. This will not kill them, but will cause irreversible mental damage. Provides less power than fully consuming souls, but siphons their mind more efficiently; granting more skill.</description>
    <iconPath>GeneIcons/BS_SoulEater_Enslave</iconPath>
    <displayOrder>100</displayOrder>
    <warmupMote>Mote_ResurrectAbility</warmupMote>
    <warmupStartSound>Resurrect_Cast</warmupStartSound>
    <hostile>true</hostile>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <verbProperties>
      <verbClass>Verb_CastAbilityTouch</verbClass>
      <drawAimPie>true</drawAimPie>
      <range>-1</range>
      <warmupTime>3</warmupTime>
      <targetParams>
        <canTargetSelf>false</canTargetSelf>
        <canTargetBuildings>false</canTargetBuildings>
        <canTargetMechs>false</canTargetMechs>
        <canTargetBloodfeeders>true</canTargetBloodfeeders>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="BigAndSmall.CompProperties_ConsumeSoul">
        <siphonSoul>
          <type>ConsumeSoul</type>
          <gainFactor>15</gainFactor>
          <gainSkill>25</gainSkill>
          
        </siphonSoul>
        <doKill>false</doKill>
        <doEnslave>true</doEnslave>
      </li>
      <li Class="CompProperties_AbilityFleckOnTarget">
        <fleckDef>PsycastPsychicEffect</fleckDef>
        <scale>1.5</scale>
      </li>
    </comps>
    <aiCanUse>false</aiCanUse>
  </AbilityDef>

  <GeneDef>
    <defName>BS_ConsumeSoulOnHit</defName>
    <label>siphon soul melee</label>
    <description>Trigger siphon soul when dealing a fatal blow in melee or close-combat. Unlike the regular version this will steal only a tiny amount of skill from the victim.\n\nFar more effective against targets with high psychic sensitivity.</description>
    <prerequisite>BS_ConsumeSoul</prerequisite>
    <iconPath>GeneIcons/BS_SoulEaterOnKill</iconPath>
    <displayCategory>BS_Soul_Category</displayCategory>
    <biostatMet>-1</biostatMet>
    <modExtensions>
      <li Class="BigAndSmall.PawnExtension">
				<siphonSoul>
          <type>KillingBlow</type>
          <gainFactor>2</gainFactor>
          
          <fromTargetSoulFactor>0.5</fromTargetSoulFactor>
          <gainSkill>5</gainSkill>
        </siphonSoul>
			</li>
		</modExtensions>
  </GeneDef>

  <GeneDef>
    <defName>BS_GainSoulOnRecruit</defName>
    <label>power from reverence</label>
    <description>Winning the hearts and minds of others fuels your soul. Literally.\n\nRecruiting new members to your faction empowers you and lets you siphon some of their skills.\n\nFor the greater good! Probably!\n\nFar more effective against targets with high psychic sensitivity and archite genes.</description>
    <iconPath>GeneIcons/BS_SoulFaith</iconPath>
    <displayCategory>Archite</displayCategory>
    <biostatArc>2</biostatArc>
    <modExtensions>
      <li Class="BigAndSmall.PawnExtension">
				<siphonSoul>
          <type>Influence</type>
          <gainOffset>10</gainOffset>
          <gainFactor>50</gainFactor>
          
          <fromTargetSoulFactor>0.1</fromTargetSoulFactor>
          <architeGeneFactor>0.5</architeGeneFactor>
          <gainSkill>30</gainSkill>
        </siphonSoul>
			</li>
		</modExtensions>
  </GeneDef>

  <GeneDef>
    <defName>BS_GainSoulOnLovin</defName>
    <label>lovin' soul drain</label>
    <description>Carriers of this gene will siphon the soul and mind from their partner when performing Lovin'\n\nEspecially strong skill-drain.\n\nFor better or worse, this is far more effective against targets with high psychic sensitivity and archite genes.</description>
    <iconPath>GeneIcons/BS_SoulLovin</iconPath>
    <displayCategory>BS_Soul_Category</displayCategory>
    <biostatMet>2</biostatMet>
    <modExtensions>
      <li Class="BigAndSmall.PawnExtension">
				<siphonSoul>
          <type>Lovin</type>
          <gainFactor>10</gainFactor>
          
          <fromTargetSoulFactor>0</fromTargetSoulFactor>
          
          <gainSkill>20</gainSkill>
          <maxXpDrainPercent>20</maxXpDrainPercent>
          <maxXPDrain>5000</maxXPDrain>
          <architeGeneFactor>0.25</architeGeneFactor>
          <fromTargetPsyfocusFactor_Max>1.0</fromTargetPsyfocusFactor_Max>
        </siphonSoul>
			</li>
		</modExtensions>
  </GeneDef>

  <GeneDef ParentName="BS_GenericGene">
    <defName>BS_SoulSiphonEfficiency</defName>
    <label>siphon efficiency</label>
    <description>Carriers of this gene are much more efficient at siphoning spiritual energy by any method.\n\nThis does little without the ability to draw soul power.</description>
    <iconPath>GeneIcons/BS_SoulSiphon</iconPath>
    <displayCategory>Archite</displayCategory>
    <biostatArc>1</biostatArc>
    <selectionWeight>0.4</selectionWeight>
    <statOffsets>
      <BS_SoulPower>0.25</BS_SoulPower>
    </statOffsets>
    <modExtensions>
      <li Class="BigAndSmall.PawnExtension">
        <soulFalloffStart>1</soulFalloffStart>
        <siphonFactorOffset>1</siphonFactorOffset>
        <siphonSkillFactorOffset>2</siphonSkillFactorOffset>
      </li>
    </modExtensions>
  </GeneDef>
</Defs>